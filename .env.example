# =====================================================
# SERCOFUN HOMENAJES DIGITALES - Configuracion General
# =====================================================
# Copia este archivo a .env y ajusta los valores
# =====================================================

# Ambiente
NODE_ENV=development

# Base de datos PostgreSQL
DB_NAME=sercofun_homenajes
DB_USER=sercofun_admin
DB_PASSWORD=ChangeMeInProduction2026!

# JWT - CAMBIAR EN PRODUCCION (minimo 32 caracteres aleatorios)
JWT_SECRET=cambia-esta-clave-secreta-en-produccion-debe-ser-muy-larga-y-aleatoria
JWT_EXPIRES_IN=7d

# CORS - Para desarrollo "*", en produccion especifica tu dominio
CORS_ORIGIN=*

# URLs
# Si pruebas localmente:
BACKEND_PUBLIC_URL=http://localhost:3001
FRONTEND_URL=http://localhost:8080
VITE_API_URL=http://localhost:3001

# Si lo despliegas en VPS, cambia a tu dominio:
# BACKEND_PUBLIC_URL=https://api.tudominio.com
# FRONTEND_URL=https://tudominio.com
# VITE_API_URL=https://api.tudominio.com

# Limites
MAX_FILE_SIZE=5242880
