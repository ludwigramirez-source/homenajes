# =============================================
# CONFIGURACION SERCOFUN HOMENAJES BACKEND
# Copia este archivo a .env y ajusta los valores
# =============================================

# Servidor
PORT=3001
NODE_ENV=development

# Base de datos PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sercofun_homenajes
DB_USER=sercofun_admin
DB_PASSWORD=ChangeMeInProduction2026!

# JWT
JWT_SECRET=cambia-esta-clave-secreta-en-produccion-debe-ser-muy-larga
JWT_EXPIRES_IN=7d

# CORS - URLs permitidas (separadas por coma)
# Para desarrollo, "*" permite todo. En produccion especifica dominios exactos.
CORS_ORIGIN=*

# Subida de archivos
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# URL publica del backend (para QR codes y enlaces)
PUBLIC_URL=http://localhost:3001

# URL del frontend (para construir QR codes que apunten al formulario)
FRONTEND_URL=http://localhost:5173
